# このファイルをコピーして .streamlit/secrets.toml を作り、実際の値を入れてください。
# secrets.toml 自体は .gitignore で除外されるのでGitHubには上がりません。
# Streamlit Community Cloudにデプロイする場合は、アプリ管理画面の
# 「Settings > Secrets」に同じ内容を貼り付けてください。

GEMINI_API_KEY = "AIzaSy..."   # https://aistudio.google.com/apikey で取得
APP_PASSWORD = "好きな合言葉"    # 身近な人にだけ伝える合言葉
